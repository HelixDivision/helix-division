# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is the checked-in template (README's `cp .env.example .env`
# setup step depends on it being tracked); everything else stays untracked.
.env*
!.env.example

# vercel
.vercel

# claude code runtime state
.claude/scheduled_tasks.lock

# typescript
*.tsbuildinfo
next-env.d.ts



# Uploaded media (Media Library) — served from disk in dev; production uses cloud storage
public/uploads/*
!public/uploads/.gitkeep
