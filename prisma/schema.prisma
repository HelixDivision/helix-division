// Helix Division database schema — see ARCHITECTURE.md#database-schema-core-models.
// v1 models are load-bearing for Phase 2. Models marked "v2 stub" exist so the
// admin architecture (ARCHITECTURE.md#admin-module-map) has a home to grow
// into without a schema migration surprise later — they are intentionally
// minimal until their admin module is actually built.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth / Users
// ---------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  name                   String?
  role                   UserRole  @default(CUSTOMER)
  researchAcknowledgedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  addresses Address[]
  orders    Order[]
  cart      Cart?
  reviews   Review[]
  accounts  Account[]
  sessions  Session[]

  @@map("users")
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String
  country    String
  phone      String?

  @@index([userId])
  @@map("addresses")
}

// Auth.js (@auth/prisma-adapter) canonical models — field names/shapes match
// the adapter's expectations exactly (see node_modules/@auth/prisma-adapter),
// not this project's usual camelCase-everything convention, so the adapter
// works as a drop-in. `Session` is unused at runtime today (lib/auth.ts uses
// `session: { strategy: "jwt" }`, not database sessions) but is required by
// the adapter's type contract and kept for future-proofing (e.g. a switch to
// database sessions). No OAuth provider is configured yet — `Account` exists
// so adding one later (see lib/auth.ts's `providers` array) needs no schema
// change, only a config addition.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Serves both email-verification and password-reset links (see
// server/services/auth.ts's issueToken/consumeToken) — `purpose`
// distinguishes the two so a stale verification link can't be replayed as a
// password reset or vice versa. `token` stores a sha256 hash, never the raw
// token (which only ever exists in the emailed/logged link itself).
enum VerificationPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  identifier String
  token      String
  purpose    VerificationPurpose
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Catalog — category-agnostic (see ARCHITECTURE.md#product--catalog-model)
// ---------------------------------------------------------------------------

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Category {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  // SEO fields (Phase 9 — Admin Dashboard manages these; mirrors Product's
  // seoTitle/seoDescription so category listing pages can generate metadata).
  seoTitle        String?
  seoDescription  String?
  // Describes which attribute keys/labels this category's products expose
  // (e.g. [{ "key": "dosage", "label": "Dosage" }] for peptides,
  // [{ "key": "size", "label": "Size" }, { "key": "color", "label": "Color" }]
  // for merch) — drives the generic PDP/filter UI without per-category code.
  attributeSchema Json     @default("[]")
  createdAt       DateTime @default(now())

  // Subcategories are Category rows, not a hardcoded string field — same
  // "category is data not code" principle as attributeSchema above.
  parentId      String?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[] @relation("CategoryHierarchy")

  products Product[]

  @@map("categories")
}

enum ShippingClass {
  STANDARD
  COLD_CHAIN
  HAZMAT
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String
  researchSummary String?
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  status          ProductStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Research-chemical-specific specifications — optional because most
  // products won't have every field populated at launch, but the PDP's
  // Specifications section is architected around this shape from day one
  // (see PROJECT_CONTEXT.md Phase 4 notes).
  purity              String?
  molecularWeight     String?
  casNumber           String?
  sequence            String?
  storageInstructions String?
  labTestingSummary   String?

  // Merchandising flags — drive homepage/shop "featured" rails and badges
  // instead of a hardcoded product list.
  featured   Boolean @default(false)
  newArrival Boolean @default(false)
  bestSeller Boolean @default(false)

  shippingClass ShippingClass @default(STANDARD)

  variants  ProductVariant[]
  images    ProductImage[]
  reviews   Review[]
  documents ProductDocument[]

  @@index([categoryId])
  @@map("products")
}

enum DocumentKind {
  COA
  LAB_REPORT
  VIDEO
  OTHER
}

// Generic home for Certificates of Analysis, lab reports, videos, and any
// future downloadable asset — one extensible list instead of a one-off
// `coaUrl`-style column per document type.
model ProductDocument {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind      DocumentKind
  label     String
  url       String
  createdAt DateTime     @default(now())

  @@index([productId])
  @@map("product_documents")
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label          String // e.g. "10MG", "Large / Black"
  sku            String   @unique
  // Nullable — null means pricing isn't finalized yet. UI shows
  // "Contact for Pricing" rather than an invented figure (see
  // PriceDisplay.tsx and getStockStatus in server/services/catalog.ts).
  price          Decimal? @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  stock          Int      @default(0)
  // Category-specific attributes, keyed per Category.attributeSchema —
  // e.g. { "dosage": "10mg" } or { "size": "L", "color": "black" }.
  attributes     Json     @default("{}")

  // Inventory management fields — populated incrementally as real stock
  // tracking comes online; `stock` above stays the simple current count,
  // these support richer low-stock/backorder UI without a schema change.
  availableQuantity Int       @default(0)
  lowStockThreshold Int       @default(5)
  backorderAllowed  Boolean   @default(false)
  restockDate       DateTime?

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

enum ImageKind {
  PRIMARY
  GALLERY
  LABEL_CLOSEUP
  PACKAGING
  LIFESTYLE
  COA_PREVIEW
}

model ProductImage {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  position  Int       @default(0)
  kind      ImageKind @default(GALLERY)

  @@index([productId])
  @@map("product_images")
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id           String   @id @default(cuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String?  @unique // guest cart identifier
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ---------------------------------------------------------------------------
// Orders / Payments (see ARCHITECTURE.md#ecommerce-order-lifecycle,
// API.md#payment-provider-interface)
// ---------------------------------------------------------------------------

// Expanded granularity vs. a single PENDING_PAYMENT/CONFIRMED pair — see
// PROJECT_CONTEXT.md Phase 5 notes. PENDING = order row created, before
// payment instructions are issued; AWAITING_PAYMENT = instructions issued,
// waiting on the customer; PAYMENT_CONFIRMED = a human/webhook has verified
// funds (distinct from PAYMENT_SUBMITTED, which is just the customer's claim).
enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAYMENT_SUBMITTED
  PAYMENT_CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id                   String      @id @default(cuid())
  orderNumber          String      @unique
  userId               String?
  user                 User?       @relation(fields: [userId], references: [id])
  email                String
  status               OrderStatus @default(PENDING)
  subtotal             Decimal     @db.Decimal(10, 2)
  // Reserved for future coupon support (src/server/services/discounts.ts) —
  // always 0 today, but total is computed as subtotal - discount + shipping + tax.
  discount             Decimal     @default(0) @db.Decimal(10, 2)
  shippingCost         Decimal     @default(0) @db.Decimal(10, 2)
  tax                  Decimal     @default(0) @db.Decimal(10, 2)
  total                Decimal     @db.Decimal(10, 2)
  currency             String      @default("USD")
  shippingAddressJson  Json
  researchAcknowledged Boolean     @default(false)
  // Fulfillment fields (Phase 9 — set by the admin "mark shipped" flow).
  trackingNumber       String?
  trackingCarrier      String?
  shippedAt            DateTime?
  // Inventory lifecycle flags (Phase 9). Explicit state, deliberately NOT
  // inferred from status + reservation policy — reserved gates release (no
  // double-release on cancel), deducted gates deduction (no double-decrement
  // of physical stock). Written only via the inventory hooks in orders.ts.
  inventoryReserved    Boolean     @default(false)
  inventoryDeducted    Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                   String         @id @default(cuid())
  orderId              String
  order                Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId            String
  variant              ProductVariant @relation(fields: [variantId], references: [id])
  nameSnapshot         String
  variantLabelSnapshot String
  imageSnapshot        String?
  priceSnapshot        Decimal        @db.Decimal(10, 2)
  quantity             Int

  @@index([orderId])
  @@map("order_items")
}

// Decided production providers: WISE, NOW_PAYMENTS, COINBASE_COMMERCE (see
// ARCHITECTURE.md#payment-architecture). BITCOIN/STRIPE/AUTHORIZE remain as
// optional/example adapters, not primary choices.
enum PaymentMethod {
  WISE
  NOW_PAYMENTS
  COINBASE_COMMERCE
  BITCOIN
  MANUAL
  STRIPE
  AUTHORIZE
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

// One row per Order, written/read only through the PaymentProvider interface
// (lib/payments/provider.ts) — see API.md#payment-provider-interface.
model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  referenceCode    String? // Wise bank-transfer reference / generic provider reference code
  btcAddress       String?
  btcInvoiceId     String?
  txHash           String?
  // Generic provider-specific rendering payload (e.g. WiseInstructions,
  // a future NOW Payments/Coinbase Commerce hosted-checkout URL) — mirrors
  // Order.shippingAddressJson's pattern of storing a structured shape that
  // varies per provider as Json rather than one column per provider.
  instructionsJson Json?
  confirmedAt      DateTime?
  createdAt        DateTime      @default(now())

  @@index([referenceCode])
  @@index([btcInvoiceId])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Content / CMS layer (see ARCHITECTURE.md#content-layer)
// ---------------------------------------------------------------------------

model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  sections       Json     @default("[]") // ordered block list: hero/richtext/faq-list/cta/...
  seoTitle       String?
  seoDescription String?
  updatedAt      DateTime @updatedAt

  @@map("pages")
}

// Shared publish lifecycle for the Research Center and Newsletter CMS
// (Phase 9.5). SCHEDULED rows become publicly visible once scheduledFor passes
// — the read queries filter on that, so no cron job is required for the MVP.
enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

// CMS-managed article categories (Phase 9.5) — data, not an enum, so the admin
// can add topics without a migration (same principle as product Category).
model ArticleTopic {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  articles Article[]

  @@map("article_topics")
}

// Contact form submissions (Prototype Launch sprint) — saved to the DB so they
// can be reviewed in the Admin Dashboard, in addition to being emailed to the
// configurable recipient (see SiteSetting).
enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())

  @@index([status])
  @@map("contact_messages")
}

// Generic admin-editable key/value settings (Prototype Launch sprint). First
// use: the contact-form recipient email. Kept a single key/value table so more
// runtime-configurable settings can be added without a migration each time.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Article {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  excerpt           String?
  // Ordered content blocks: [{ type: "paragraph"|"heading"|"image"|"pdf", ... }]
  body              Json          @default("[]")
  featuredImageUrl  String?
  status            ContentStatus @default(DRAFT)
  featured          Boolean       @default(false)
  homepagePlacement Boolean       @default(false)
  publishedAt       DateTime?
  scheduledFor      DateTime?
  author            String?
  tags              String[]      @default([])
  // Downloadable PDFs surfaced on the article: [{ label, url }]
  attachments       Json          @default("[]")
  seoTitle          String?
  seoDescription    String?
  topicId           String?
  topic             ArticleTopic? @relation(fields: [topicId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([topicId])
  @@map("articles")
}

// Newsletter CMS (Phase 9.5). Shares ContentStatus + the block-body/attachments
// shape with Article, but kept a separate model — different audience surface,
// different lifecycle (no scheduling requirement, has a subscriber list).
model Newsletter {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  excerpt          String?
  body             Json          @default("[]")
  featuredImageUrl String?
  status           ContentStatus @default(DRAFT)
  featured         Boolean       @default(false)
  category         String?
  publishedAt      DateTime?
  attachments      Json          @default("[]")
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@map("newsletters")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String? // where they subscribed from, e.g. "footer"
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ---------------------------------------------------------------------------
// Media Library (Phase 9.5) — tracked assets behind the StorageProvider
// abstraction (src/lib/storage). `url` is provider-relative-public (e.g.
// /uploads/... for the local adapter). Reused everywhere: product images/
// galleries, category images/banners, homepage/hero graphics, article/
// newsletter images, and COA PDFs.
// ---------------------------------------------------------------------------

enum MediaKind {
  IMAGE
  PDF
}

model MediaAsset {
  id           String    @id @default(cuid())
  filename     String // stored filename on disk (unique, slugified + suffixed)
  originalName String
  url          String
  mimeType     String
  kind         MediaKind
  sizeBytes    Int
  folder       String    @default("general")
  alt          String?
  width        Int?
  height       Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([kind])
  @@index([folder])
  @@map("media_assets")
}

// ---------------------------------------------------------------------------
// Analytics (Phase 9.5) — first-party event capture powering the admin
// Analytics dashboard. visitorId (persistent cookie) distinguishes unique vs
// returning; sessionId (session cookie) groups a visit. Store metrics
// (revenue/AOV/best-sellers/customer growth) come from Order/User; these
// events add traffic/funnel/device/geo/search. GA4 is the documented
// production complement (NEXT_PUBLIC_GA_ID), not a replacement for these.
// ---------------------------------------------------------------------------

enum AnalyticsEventType {
  PAGE_VIEW
  PRODUCT_VIEW
  ADD_TO_CART
  BEGIN_CHECKOUT
  PURCHASE
  SEARCH
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  visitorId  String
  sessionId  String
  path       String?
  referrer   String?
  device     DeviceType?
  country    String?
  searchTerm String?
  productId  String?
  orderId    String?
  value      Decimal?           @db.Decimal(10, 2)
  createdAt  DateTime           @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([visitorId])
  @@map("analytics_events")
}

model FAQItem {
  id       String  @id @default(cuid())
  question String
  answer   String
  category String?
  position Int     @default(0)

  @@map("faq_items")
}

// ---------------------------------------------------------------------------
// v2 stubs — scaffolded now so the admin modules in ARCHITECTURE.md#admin-module-map
// have a schema home; full CRUD/business logic is built out with each module.
// ---------------------------------------------------------------------------

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id         String       @id @default(cuid())
  code       String       @unique
  type       DiscountType
  value      Decimal      @db.Decimal(10, 2)
  expiresAt  DateTime?
  usageLimit Int?
  timesUsed  Int          @default(0)

  @@map("coupons")
}

model Discount {
  id     String       @id @default(cuid())
  name   String
  type   DiscountType
  value  Decimal      @db.Decimal(10, 2)
  rule   Json // e.g. { "minSubtotal": 100 } — evaluated by the discount service once built
  active Boolean      @default(false)

  @@map("discounts")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("reviews")
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String
  countries String[] // ISO country codes
  rate      Decimal  @db.Decimal(10, 2)

  @@map("shipping_zones")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String
  reason    String
  status    ReturnStatus @default(REQUESTED)
  createdAt DateTime     @default(now())

  @@map("return_requests")
}
