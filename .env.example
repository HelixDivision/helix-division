# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/helix_division"

# --- Auth.js ---
# Session/cookie settings themselves (maxAge, updateAge, httpOnly/sameSite)
# live in src/lib/auth.ts, not here — see AUTH.md#session-lifecycle.
AUTH_SECRET="generate-with-npx-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Future OAuth provider(s) — illustrative only, not configured or required
# today. Credentials-only for now; adding a provider is a config addition
# (one new entry in lib/auth.ts's `providers` array + these two vars), not a
# rework. See AUTH.md#future-oauth-integration-points.
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Analytics (optional) ---
# Google Analytics 4 measurement id. The GA script only renders when set;
# the first-party analytics dashboard works regardless. See Phase 9.5.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Transactional email (Resend) ---
# API key for the Resend SDK (https://resend.com). When set, transactional
# emails (order confirmation/notification, contact, password reset, email
# verification, newsletter) are sent for real; when unset, sends are logged to
# the server console so the app runs locally without a key. Never commit a real
# key — set it in the environment (locally in .env, on Vercel in Project
# Settings → Environment Variables).
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# "From" address for all outbound mail. The domain (helixdivision.com) must be
# verified in Resend. Defaults to "Helix Division <support@helixdivision.com>".
# EMAIL_FROM="Helix Division <support@helixdivision.com>"
# Recipient for internal/staff notifications (new orders, contact submissions,
# new newsletter subscribers). Defaults to support@helixdivision.com.
# SUPPORT_EMAIL="support@helixdivision.com"

# --- File storage (Vercel Blob) ---
# Read/write token for Vercel Blob. On Vercel, connect a Blob store to the project
# (Storage → Blob) and this is injected automatically. When set, Media Library /
# COA / CMS uploads go to Vercel Blob (durable, and required on Vercel's read-only
# serverless filesystem). When unset, uploads use the local filesystem
# (public/uploads) for dev. Never hardcode a real token.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# --- Contact form (optional) ---
# Fallback recipient for contact submissions (the admin-editable Setting takes
# precedence). Submissions are always saved under Admin → Messages.
# CONTACT_RECIPIENT_EMAIL="support@helixdivision.com"
# Google reCAPTCHA v2 checkbox — when both are set the contact form renders the
# widget and the server verifies it; when unset, a honeypot protects the form.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# RECAPTCHA_SECRET_KEY=""

# --- Payments ---
# Comma-separated list of adapter ids to enable at checkout. Decided production
# providers are "wise", "now-payments", "coinbase-commerce" — see
# ARCHITECTURE.md#payment-architecture. Only Wise is functionally implemented
# today; NOW Payments/Coinbase Commerce are scaffolded (throw until their real
# API integration lands, see ROADMAP.md).
PAYMENT_PROVIDERS_ENABLED="wise,now-payments,coinbase-commerce"

# Wise (manual bank-transfer reconciliation — no public payment API used)
WISE_ACCOUNT_HOLDER=""
WISE_IBAN=""
WISE_BIC=""

# NOW Payments — non-custodial crypto gateway (production provider, not yet integrated)
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# Coinbase Commerce — hosted crypto checkout (production provider, not yet integrated)
COINBASE_COMMERCE_API_KEY=""
COINBASE_COMMERCE_WEBHOOK_SECRET=""

# Bitcoin via BTCPay Server (self-hosted, non-custodial) — optional alternative
# to Coinbase Commerce, not part of the decided production trio
BTCPAY_URL=""
BTCPAY_API_KEY=""
BTCPAY_STORE_ID=""

# Stripe adapter — scaffolded example only; not usable for this catalog
# (Stripe's ToS prohibits research-chemical merchants)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Authorize.net adapter — scaffolded example only; not a decided provider
AUTHORIZE_API_LOGIN_ID=""
AUTHORIZE_TRANSACTION_KEY=""
